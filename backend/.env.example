# Copiá este archivo como ".env" y completá los valores

# Tu nombre de usuario de TikTok (sin @)
TIKTOK_USERNAME=tu_usuario_tiktok

# Puerto del servidor (el frontend se conecta a este puerto)
PORT=3000

# Diamantes mínimos de un regalo para disparar "comida bonus"
GIFT_BONUS_FOOD_MIN=100

# Diamantes mínimos de un regalo para disparar "obstáculo"
GIFT_OBSTACLE_MIN=1000
